{
  "name": "@form-validator-js/validators",
  "version": "1.0.0",
  "description": "Built-in validators for form-validator-js: required, minLength, maxLength, pattern, equalsTo, checkedCount, numeric, min, max, step.",
  "keywords": [
    "form",
    "validation",
    "validators",
    "required",
    "pattern",
    "typescript"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --project validators"
  },
  "author": "Ruslan Gilmullin <mellonis@yandex.ru>",
  "license": "MIT",
  "peerDependencies": {
    "@form-validator-js/core": "1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mellonis/form-validator-js.git",
    "directory": "packages/validators"
  },
  "homepage": "https://github.com/mellonis/form-validator-js#readme",
  "bugs": {
    "url": "https://github.com/mellonis/form-validator-js/issues"
  }
}
